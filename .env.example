# Copy this file to .env and fill in local secrets as needed.
# Do not commit real API keys.

# OpenAI API key, used only when OpenAI features are explicitly enabled.
OPENAI_API_KEY=

# Anthropic/Claude API key, reserved for future Claude support.
ANTHROPIC_API_KEY=

# Zotero Web API, reserved for future optional Zotero API support.
# Keep empty unless explicitly enabling Zotero Web API workflows.
ZOTERO_API_KEY=
ZOTERO_USER_ID=
