# Copy this file to .env and fill in local secrets as needed.
# Do not commit real API keys.

# OpenAI API key, used only when OpenAI features are explicitly enabled.
OPENAI_API_KEY=

# Anthropic/Claude API key, reserved for future Claude support.
ANTHROPIC_API_KEY=

# Zotero Web API, reserved for future optional Zotero API support.
# Keep empty unless explicitly enabling Zotero Web API workflows.
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# External academic search, used only when explicitly enabled with --external-search.
SCOPUS_API_KEY=
INST_TOKEN=

# Google Scholar fallback pipeline (corroborly.engine.scholar_providers.
# ScholarDataService). All optional -- every key can be left empty and the
# service just falls through to the next backend. Order: SerpApi ->
# Semantic Scholar -> `scholarly` package (needs the `scholar` extra,
# no key) -> ScholarAPI.net (currently an unimplemented stub).
SERPAPI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
SCHOLARAPI_NET_API_KEY=

# Local API (`corroborly serve` / the deployed Docker image). See
# docs/api/CONTRACT.md "Authentication" and docs/DEPLOY.md.
# Required, both of them: every /api/v1 route except /api/v1/auth/login fails
# closed (503 auth_not_configured) until both are set. Still a single shared
# credential pair, not per-user accounts -- see TODO.md's multi-tenant item
# for the larger, separate feature that would add real per-user accounts.
# Never commit real values.
CORROBORLY_API_USERNAME=
CORROBORLY_API_PASSWORD=
# Optional: session expiry in hours (default 12).
CORROBORLY_API_SESSION_HOURS=
# Optional: confines every `workspace` request to this root (relative paths
# joined to it, absolute paths outside it rejected). Set this when deploying
# against a mounted volume; leave empty for local single-user CLI-equivalent
# use, where any absolute path is accepted as today.
CORROBORLY_WORKSPACE_ROOT=
# Optional: batch artefact upload limits (defaults 25 files / 50 MB per file).
CORROBORLY_UPLOAD_MAX_FILES=
CORROBORLY_UPLOAD_MAX_FILE_SIZE_MB=

# Optional secondary database backend (Phase 24). SQLite stays the always-on,
# zero-config default with zero new required dependencies -- leave this unset
# (or "sqlite") unless you deliberately want a mirrored MariaDB/PostgreSQL
# copy of the SQLite cache. Never activates automatically: setting this only
# makes `corroborly db init/sync/status` (or the web Data & Admin panel) offer
# an explicit "activate now?" prompt. Requires the matching optional extra
# (`pip install -e '.[postgres]'` or `.[mariadb]'`).
CORROBORLY_DB_BACKEND=

# Required when CORROBORLY_DB_BACKEND=postgres.
CORROBORLY_POSTGRES_HOST=
CORROBORLY_POSTGRES_PORT=
CORROBORLY_POSTGRES_USER=
CORROBORLY_POSTGRES_PASSWORD=
CORROBORLY_POSTGRES_DATABASE=

# Required when CORROBORLY_DB_BACKEND=mariadb.
CORROBORLY_MARIADB_HOST=
CORROBORLY_MARIADB_PORT=
CORROBORLY_MARIADB_USER=
CORROBORLY_MARIADB_PASSWORD=
CORROBORLY_MARIADB_DATABASE=

# Optional audio/video transcription (Phase 30), via a local sibling
# SourceScribe checkout invoked as a subprocess -- never imported, so this
# only needs a filesystem path, not a package dependency. Leave unset to
# disable `corroborly transcribe *` / the web
# transcription panel entirely (they report "not available" instead of
# failing). Point it at a SourceScribe checkout with its own dependencies
# installed (ffmpeg + a local Whisper backend for the zero-API-key default
# path; OPENAI_API_KEY only needed if a job explicitly opts into --ai).
# Supported extensions: .flac .m4a .mp3 .mp4 .mpeg .mpga .ogg .wav .webm.
CORROBORLY_SOURCESCRIBE_PATH=
# Optional: single-file transcription upload limit in MB (default 500).
CORROBORLY_TRANSCRIBE_MAX_FILE_SIZE_MB=
